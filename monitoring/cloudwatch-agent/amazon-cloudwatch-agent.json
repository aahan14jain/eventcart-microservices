{
  "agent": {
    "metrics_collection_interval": 60,
    "run_as_user": "cwagent",
    "logfile": "/opt/aws/amazon-cloudwatch-agent/logs/amazon-cloudwatch-agent.log"
  },
  "logs": {
    "logs_collected": {
      "files": {
        "collect_list": [
          {
            "file_path": "/var/log/eventcart/order-service.log",
            "log_group_name": "order-service",
            "log_stream_name": "{instance_id}/stdout",
            "timezone": "UTC",
            "retention_in_days": 14
          },
          {
            "file_path": "/var/log/eventcart/inventory-service.log",
            "log_group_name": "inventory-service",
            "log_stream_name": "{instance_id}/stdout",
            "timezone": "UTC",
            "retention_in_days": 14
          },
          {
            "file_path": "/var/log/eventcart/payment-service.log",
            "log_group_name": "payment-service",
            "log_stream_name": "{instance_id}/stdout",
            "timezone": "UTC",
            "retention_in_days": 14
          },
          {
            "file_path": "/var/log/eventcart/notification-service.log",
            "log_group_name": "notification-service",
            "log_stream_name": "{instance_id}/stdout",
            "timezone": "UTC",
            "retention_in_days": 14
          }
        ]
      },
      "journal": {
        "collect_list": [
          {
            "log_group_name": "order-service",
            "log_stream_name": "{instance_id}/journal",
            "filters": {
              "unit": "order-service.service"
            },
            "retention_in_days": 14
          },
          {
            "log_group_name": "inventory-service",
            "log_stream_name": "{instance_id}/journal",
            "filters": {
              "unit": "inventory-service.service"
            },
            "retention_in_days": 14
          },
          {
            "log_group_name": "payment-service",
            "log_stream_name": "{instance_id}/journal",
            "filters": {
              "unit": "payment-service.service"
            },
            "retention_in_days": 14
          },
          {
            "log_group_name": "notification-service",
            "log_stream_name": "{instance_id}/journal",
            "filters": {
              "unit": "notification-service.service"
            },
            "retention_in_days": 14
          }
        ]
      }
    },
    "force_flush_interval": 5
  },
  "metrics": {
    "namespace": "EventCart/EC2",
    "append_dimensions": {
      "InstanceId": "${aws:InstanceId}",
      "InstanceType": "${aws:InstanceType}",
      "ImageId": "${aws:ImageId}"
    },
    "aggregation_dimensions": [
      ["InstanceId"]
    ],
    "metrics_collected": {
      "cpu": {
        "measurement": [
          "cpu_usage_idle",
          "cpu_usage_iowait",
          "cpu_usage_user",
          "cpu_usage_system"
        ],
        "metrics_collection_interval": 60,
        "totalcpu": true
      },
      "disk": {
        "measurement": [
          "used_percent",
          "inodes_free"
        ],
        "metrics_collection_interval": 60,
        "resources": [
          "*"
        ],
        "drop_device": [
          "^(loop|ram|sr|dm-)[0-9]*$",
          "^nvme[0-9]+n[0-9]+p[0-9]+$"
        ],
        "ignore_file_system_types": [
          "sysfs",
          "devtmpfs",
          "tmpfs",
          "overlay",
          "squashfs"
        ]
      },
      "diskio": {
        "measurement": [
          "io_time",
          "write_bytes",
          "read_bytes"
        ],
        "metrics_collection_interval": 60,
        "resources": [
          "*"
        ]
      },
      "mem": {
        "measurement": [
          "mem_used_percent",
          "mem_available_percent"
        ],
        "metrics_collection_interval": 60
      },
      "swap": {
        "measurement": [
          "swap_used_percent"
        ],
        "metrics_collection_interval": 60
      },
      "net": {
        "measurement": [
          "bytes_sent",
          "bytes_recv"
        ],
        "metrics_collection_interval": 60,
        "resources": [
          "*"
        ]
      }
    }
  }
}
